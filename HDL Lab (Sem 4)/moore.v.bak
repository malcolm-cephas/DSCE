seq_moore(input x, input clk , input rst , output reg y );
reg [1:0]cst;
reg [1:0]nst;
parameter s0 = 2'b00 , s1 = 2'b01 , s2 = 2'b10 , s3 = 2'b11;
always @(cst or x)
begin
case(cst)
s0: begin
y=0;
if (x)
nst = s1;
else
nst = cst;
end
s1: begin
y=0;
if (x==0)
nst = s2;
else
nst = cst;
end
s2: begin
y=0;
if (x)
nst = s3;
else
nst = s0;
end
s3: begin
y=1;
if (x)
nst = s1;
else
nst = s2;
end
default: nst = s0 ;
endcase
end
always@(posedge clk)
begin
if(rst)
cst <= s0;
else
cst <= nst;
end
endmodule